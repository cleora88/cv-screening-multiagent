# ── CV Screening Multi-Agent — environment variables ──────────────────────────
# Copy this file to .env and adjust values as needed.
# .env is git-ignored and loaded automatically via python-dotenv.

# ── Ollama LLM backend ────────────────────────────────────────────────────────
# Install: https://ollama.com/download
# Pull a model:    ollama pull llama3.2
# Start server:    ollama serve
# Then run:        python -m src.main --ollama
#
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Runtime ───────────────────────────────────────────────────────────────────
LOG_DIR=logs
MODEL_PATH=models/cv_fit_model.pt
BORDERLINE_LOW=0.45
BORDERLINE_HIGH=0.55
